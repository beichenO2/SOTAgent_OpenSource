      "timeout_ms": 10000
    },
    {
      "id": "sotagent.projects.list",
      "service_name": "sotagent-api",
      "description": "列出所有已注册项目",
      "transport": "http",
      "endpoint": "/api/projects",
      "method": "GET",
      "idempotent": true,
      "side_effects": false,
      "timeout_ms": 3000
    },
    {
      "id": "sotagent.services.list",
      "service_name": "sotagent-api",
      "description": "列出所有管理的服务及其状态",
      "transport": "http",
      "endpoint": "/api/services",
      "method": "GET",
      "idempotent": true,
      "side_effects": false,
