      "endpoint": "/api/services/:id/start",
      "method": "POST",
      "idempotent": false,
      "side_effects": true,
      "timeout_ms": 30000,
      "status": "pending_migration",
      "migration_note": "已外包到 PolarProcess (port 11055)。facade bridge 已启用，旧端点透明转发到 PolarProcess。"
    },
    {
      "id": "sotagent.crystals.match",
      "service_name": "sotagent-api",
      "description": "用自然语言查询匹配已结晶的知识（经验沉淀）",
      "transport": "http",
      "endpoint": "/api/crystals/match",
      "method": "POST",
      "input_schema": {
        "type": "object",
        "required": [
