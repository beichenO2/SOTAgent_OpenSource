{
  "version": 2,
  "ports": {
    "sotagent_api": 4800,
    "sotagent_console": 4880,
    "polar_private": 12790,
    "autooffice": 3900,
    "infoforge_api": 3901,
    "infoforge_sse": 3902,
    "knowlever_rag": 18080,
    "knowlever_wiki": 18085,
    "polarclaw_web": 3910,
    "polarpilot": 4900,
    "polarport_api": 11050,
    "polarmemory": 3100,
    "polarcop_web_dev": 5180,
    "polarcop_hub": 8040,
    "digist_api": 3800,
    "lm_studio": 1234,
    "vocab_app": 3000,
    "llama_server": 8080,
    "polarcop_stepflow": 8765,
    "ai_daily_digest": 8785,
    "knowlever_embedding": 8801,
    "ollama": 11434,
    "tqsdk_collector": 18900,
    "claude_code_viz": 19120,
    "polar_process": 11055,
    "polarops": 11065,
    "polarui": 5170
  },
  "sentinel": {
    "poll_interval_sec": 30,
    "use_fswatch": true
  },
  "resource_monitor": {
    "interval_sec": 60,
    "cpu_idle_threshold": 40,
    "mem_idle_threshold_percent": 70
  },
  "sync": {
    "auto_sync_types": [
      "skill",
      "config"
    ],
    "suggest_sync_types": [
      "architecture",
      "workflow",
      "methodology",
      "framework",
      "pattern"
    ]
  },
  "scheduler": {
    "max_concurrent_heavy_tasks": 1,
    "pause_on_cpu_above": 80,
    "pause_on_mem_above_percent": 85
  },
  "devices": {
    "macbook-pro": {
      "display_name": "MacBook Pro",
      "role": "dev",
      "tailscale_ip": "<tailscale-ip>",
      "ssh_user": "macbook",
      "capabilities": [
        "dev",
        "web",
        "agent"
      ]
    },
    "Mac-Studio": {
      "display_name": "Mac Studio",
      "role": "compute",
      "tailscale_ip": "<tailscale-ip>",
      "capabilities": [
        "compute",
        "gpu",
        "whisper",
        "llm-local",
        "dev"
      ],
      "ssh_user": "mac"
    }
  },
  "polar_private": {
    "base_url": "http://127.0.0.1:12790",
    "auto_sync": {
      "enabled": true,
      "interval_minutes": 30
    }
  },
  "silent_restart_window_sec": 7200,
  "process_manager": {
    "health_check_interval_sec": 120,
    "auto_start_delay_sec": 15,
    "restart_cooldown_sec": 15,
    "startup_grace_sec": 60
  },
  "sandbox": {
    "default_nice_priority": 10,
    "default_max_duration_sec": 86400,
    "default_output_timeout_sec": 1800,
    "monitor_interval_sec": 30,
    "prune_completed_after_sec": 3600
  },
  "peer_sync": {
    "enabled": true,
    "heartbeat_interval_sec": 30,
    "auto_pull_on_clean": true,
    "scan_root": "~/Polarisor",
    "alert_on_conflict": true,
    "peer_secret_env": "SOTAGENT_PEER_SECRET",
    "global_ignore": [
      ".planning/sync-log.jsonl",
      ".planning/**/*.tmp"
    ],
    "project_whitelist": [
      "digist",
      "macbook",
      "SOTAgent",
      "PolarisLab",
      "PolarisVault",
      "PolarPrivate"
    ],
    "_whitelist_note": "AutoOffice removed 2026-07-09: its origin is the sanitized open-source mirror (unrelated history); peer-sync pull --rebase wedged the repo in a month-long detached rebase. Publish via opensource-mirror-sync instead.",
    "rsync_large_files": {
      "enabled": true,
      "ssh_port": 22,
      "exclude_patterns": [
        ".git/",
        "node_modules/",
        ".DS_Store"
      ],
      "bandwidth_limit_kbps": 0
    }
  },
  "gateway": {
    "enabled": true,
    "base_path": "/gw",
    "routes": [
      {
        "prefix": "polarprivate",
        "target_port": 12790,
        "service_id": "polarprivate-backend"
      },
      {
        "prefix": "digist",
        "target_port": 3800,
        "service_id": "digist"
      },
      {
        "prefix": "autooffice",
        "target_port": 3900,
        "service_id": "autooffice"
      },
      {
        "prefix": "clock",
        "target_port": 15550,
        "service_id": "polarclock-backend"
      },
      {
        "prefix": "gsd2",
        "target_port": 8765,
        "service_id": "gsd2-hub"
      },
      {
        "prefix": "knowlever",
        "target_port": 18080,
        "service_id": "knowlever-rag"
      },
      {
        "prefix": "polarclaw",
        "target_port": 0,
        "service_id": "polarclaw-web"
      },
      {
        "prefix": "pcweb",
        "target_port": 5180,
        "service_id": "polarcop-web-dev"
      }
    ]
  },
  "port_governance": {
    "rule": "所有端口必须以 0 或 5 结尾",
    "reserved_ports": [
      3000,
      8000,
      8080
    ],
    "reserved_reason": "3000/8000 是经典默认端口易冲突，8080 保留"
  },
  "security": {
    "bind_host": "0.0.0.0",
    "auth_token_env": "SOTAGENT_AUTH_TOKEN",
    "public_routes": [
      "/api/status",
      "/api/peer/heartbeat",
      "/api/peer/notify",
      "/api/peer/notify-push",
      "/api/ports/config"
    ]
  },
  "ssot_watcher": {
    "enabled": true,
    "debounce_ms": 500,
    "watch_patterns": [
      "polaris.json",
      "PolarSoul.md",
      "capabilities.json"
    ],
    "log_file": "~/.sotagent/logs/ssot-events.jsonl",
    "polling_interval_sec": 60
  },
  "_built_in_services_note": "Emptied 2026-07-09: PolarProcess (:11055) is the sole service registry/lifecycle authority (Agent_core P27). Every entry here was re-registered on each SOTAgent boot, overwriting PolarProcess records (dual-manager races, e.g. :3900). All 9 former entries verified present in PolarProcess before removal. Register new services via PolarProcess /api/services/register or SOTAgent/scripts/register-all-services.sh.",
  "built_in_services": []
}
